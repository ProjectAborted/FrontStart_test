{
  "ConnectionStrings": {
    // Database connection string using Localhost and Windows Authentication
    "DefaultConnection": "Server=localhost;Database=LibraryDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // Allows API to respond to requests from any domain/host
  "AllowedHosts": "*"
}